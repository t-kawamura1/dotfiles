#!/usr/bin/env bash

# GitHub Releases から gitleaks をバージョン固定で取得し、
# チェックサム検証後にインストールします。

set -euo pipefail

GITLEAKS_VERSION="v8.30.1"
VERSION="${GITLEAKS_VERSION#v}"

# 既存バージョンが同じか新しい場合はスキップ
vergte() { [ "$1" = "$2" ] && return 0 || [ "$(printf '%s\n%s' "$1" "$2" | sort -V | tail -n1)" = "$1" ]; }

if command -v gitleaks >/dev/null 2>&1; then
  INSTALLED_VER=$(gitleaks version 2>/dev/null)
  INSTALLED_VER="${INSTALLED_VER#v}"
  if [ -n "$INSTALLED_VER" ] && vergte "$INSTALLED_VER" "$VERSION"; then
    echo "gitleaks $INSTALLED_VER is already installed (>= $VERSION). Skipping."
    exit 0
  fi
fi

OS_RAW="$(uname -s)"
ARCH_RAW="$(uname -m)"

case "$OS_RAW" in
  Linux)
    OS="linux"
    ;;
  Darwin)
    OS="darwin"
    ;;
  *)
    echo "Unsupported OS: $OS_RAW" >&2
    exit 1
    ;;
esac

case "$ARCH_RAW" in
  x86_64)
    ARCH="x64"
    ;;
  aarch64|arm64)
    ARCH="arm64"
    ;;
  *)
    echo "Unsupported architecture: $ARCH_RAW" >&2
    exit 1
    ;;
esac

if ! command -v curl >/dev/null 2>&1; then
  echo "curl is required" >&2
  exit 1
fi

if ! command -v tar >/dev/null 2>&1; then
  echo "tar is required" >&2
  exit 1
fi

if ! command -v grep >/dev/null 2>&1; then
  echo "grep is required" >&2
  exit 1
fi

if ! command -v awk >/dev/null 2>&1; then
  echo "awk is required" >&2
  exit 1
fi

if ! command -v shasum >/dev/null 2>&1 && ! command -v sha256sum >/dev/null 2>&1; then
  echo "sha256sum or shasum is required" >&2
  exit 1
fi

LOCAL_BIN="$HOME/.local/bin"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

ARCHIVE="gitleaks_${VERSION}_${OS}_${ARCH}.tar.gz"
CHECKSUM_FILE="gitleaks_${VERSION}_checksums.txt"
BASE_URL="https://github.com/gitleaks/gitleaks/releases/download/${GITLEAKS_VERSION}"
URL="${BASE_URL}/${ARCHIVE}"
CHECKSUM_URL="${BASE_URL}/${CHECKSUM_FILE}"

echo "Installing gitleaks ${GITLEAKS_VERSION} (${OS}/${ARCH})"

echo "Downloading: $URL"
curl -fsSL "$URL" -o "$TMP_DIR/$ARCHIVE"
echo "Downloading: $CHECKSUM_URL"
curl -fsSL "$CHECKSUM_URL" -o "$TMP_DIR/checksums.txt"

CHECKSUM_LINE=$(grep "  ${ARCHIVE}$" "$TMP_DIR/checksums.txt" || true)
if [ -z "$CHECKSUM_LINE" ]; then
  echo "Checksum entry not found for ${ARCHIVE}" >&2
  exit 1
fi

EXPECTED_SUM=$(echo "$CHECKSUM_LINE" | awk '{print $1}')
if command -v sha256sum >/dev/null 2>&1; then
  ACTUAL_SUM=$(sha256sum "$TMP_DIR/$ARCHIVE" | awk '{print $1}')
else
  ACTUAL_SUM=$(shasum -a 256 "$TMP_DIR/$ARCHIVE" | awk '{print $1}')
fi

if [ "$EXPECTED_SUM" != "$ACTUAL_SUM" ]; then
  echo "Checksum verification failed for ${ARCHIVE}" >&2
  exit 1
fi
echo "Checksum verified."

tar -xzf "$TMP_DIR/$ARCHIVE" -C "$TMP_DIR"

if [[ ! -f "$TMP_DIR/gitleaks" ]]; then
  echo "gitleaks binary not found in archive" >&2
  exit 1
fi

install -m 0755 "$TMP_DIR/gitleaks" "$LOCAL_BIN/gitleaks"

echo "Installed: $LOCAL_BIN/gitleaks"
"$LOCAL_BIN/gitleaks" version | head -n 1
